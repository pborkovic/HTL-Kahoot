# Application
APP_NAME="HTL Kahoot"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80
APP_SSL_PORT=443

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=htl_kahoot
DB_USERNAME=postgres
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
